      "patch": "@@ -0,0 +1,46 @@\n+.root {\n+  display: inline-block;\n+  position: relative;\n+}\n+\n+.content {\n+  position: absolute;\n+  z-index: 20;\n+  outline-width: 0;\n+  display: none;\n+  top: 100%;\n+  left: 0;\n+  transform: translate(-0.5em, 5px);\n+  min-width: 120px;\n+  max-width: 260px;\n+  border: 2px solid var(--color15);\n+  border-radius: 3px;\n+  padding: 0 0 5px;\n+}\n+\n+.items {\n+  padding: 5px 0;\n+\n+  &:last-child {\n+    padding-bottom: 0;\n+  }\n+}\n+\n+.title {\n+  &::after {\n+    content: '\\25BE';\n+    margin-left: 2px;\n+  }\n+}\n+\n+.active > .content {\n+  display: block;\n+}\n+\n+.themeDark > .content {\n+  background-color: var(--color8);\n+}\n+\n+.themeLight > .content {\n+  background-color: var(--color6);\n+}"
