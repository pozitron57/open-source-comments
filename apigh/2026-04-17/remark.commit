      "status": "modified",
      "additions": 3,
      "deletions": 2,
      "changes": 5,
      "blob_url": "https://github.com/umputun/remark42/blob/94d1f6e22400c2013ee3903e50a4c48124f1dcb8/frontend%2Fapps%2Fremark42%2Fapp%2Fcomponents%2Fauth%2Fauth.utils.ts",
      "raw_url": "https://github.com/umputun/remark42/raw/94d1f6e22400c2013ee3903e50a4c48124f1dcb8/frontend%2Fapps%2Fremark42%2Fapp%2Fcomponents%2Fauth%2Fauth.utils.ts",
