      "blob_url": "https://github.com/isso-comments/isso/blob/1a6e28cfee3ea447dff836169b82409fbb9b3c54/isso%2Fjs%2Fapp%2Ftemplates%2Fpostbox.js",
      "raw_url": "https://github.com/isso-comments/isso/raw/1a6e28cfee3ea447dff836169b82409fbb9b3c54/isso%2Fjs%2Fapp%2Ftemplates%2Fpostbox.js",
